# ===========================================
# Minecraft Server Configuration
# ===========================================

# Server Settings
MC_VERSION=1.21.4
PAPER_BUILD=latest
SERVER_MEMORY=4G
DIFFICULTY=normal
GAMEMODE=survival
MAX_PLAYERS=20
VIEW_DISTANCE=12
MOTD=Cross-Platform Minecraft Server
SEED=

# GeyserMC Settings (Bedrock cross-play)
GEYSER_VERSION=latest
FLOODGATE_VERSION=latest

# AWS Settings
AWS_REGION=us-east-1
INSTANCE_TYPE=t3.medium
KEY_PAIR_NAME=minecraft-key
S3_BACKUP_BUCKET=minecraft-world-backups

# Backup Schedule (cron expression for backup frequency)
BACKUP_CRON="0 */6 * * *"
